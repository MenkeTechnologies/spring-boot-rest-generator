package {{mainPackageName}}.rest

import org.springframework.web.bind.annotation.*
import org.springframework.beans.factory.annotation.Autowired

import {{mainPackageName}}.entity.{{entityName}}
import {{mainPackageName}}.dao.{{entityName}}Dao

import {{mainPackageName}}.utils.GlobalConstants

@RestController
@RequestMapping({{restServicePrefix}} + "/{{serviceName}}")
class {{entityName}}Resource {

    @Autowired
    {{entityName}}Dao dao

    @GetMapping
    List<{{entityName}}> readAll() {
        dao.findAll()
    }

    @GetMapping("/{id}")
    {{entityName}} read(@PathVariable("id") Long id) {
        dao.findOne(id)
    }

    @PostMapping
    {{entityName}} create(@RequestBody {{entityName}} entity) {
        dao.save(entity)
    }

    @PutMapping
    {{entityName}} update(@RequestBody {{entityName}} entity) {
        dao.save(entity)
    }

    @DeleteMapping("/{id}")
    boolean delete(@PathVariable("id") Long id) {
        dao.delete(id)
        true
    }

    @DeleteMapping
    boolean deleteAll(@RequestBody List<{{entityName}}> entityList) {
        dao.deleteAll(entityList)
        true
    }

}
